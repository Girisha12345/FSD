# Django Configuration
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-one
ALLOWED_HOSTS=yourdomain.onrender.com,127.0.0.1,localhost

# Database (SQLite for local, PostgreSQL for production on Render)
# For local: sqlite:///db.sqlite3
# For production: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
